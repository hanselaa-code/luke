# Auth.js Secrets
# Generate a secret using: npx auth secret
AUTH_SECRET=
AUTH_TRUST_HOST=true

# Google OAuth Credentials
# Obtain these from: https://console.cloud.google.com/
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Deployment (Firebase App Hosting / Proxy)
# Recommended AUTH_URL for production
AUTH_URL=https://luke--luke-b5b5d.europe-west4.hosted.app
NEXTAUTH_URL=http://localhost:3000
